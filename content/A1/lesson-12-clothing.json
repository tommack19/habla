      {
        "spanish": "Llevo una camisa blanca.",
        "english": "I am wearing a white shirt."
      },
      {
        "spanish": "Uso zapatos negros.",
        "english": "I wear black shoes."
      },
      {
        "spanish": "La chaqueta es pequena.",
        "english": "The jacket is small."
      }
    ],
    "practicePrompt": "Tell Carlos what you are wearing today and whether it matches the weather."
  },
