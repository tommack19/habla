  "grammar": {
    "topic": "Greeting politely and choosing formal or informal speech",
    "explanation": "Spanish greetings change depending on time of day, formality, and region. Use tú forms with people you know or peers. Use usted forms when you want to sound respectful.",
    "notes": [
      {
        "title": "Tú vs usted",
        "text": "Use tú for informal situations and usted for formal or respectful situations."
      },
      {
        "title": "Me llamo vs soy",
        "text": "Me llamo is clear and textbook-friendly. Soy is shorter and natural when giving your name."
      },
      {
        "title": "Buenos vs buenas",
        "text": "Buenos días uses buenos. Buenas tardes and buenas noches use buenas."
      },
      {
        "title": "Encantado / encantada",
        "text": "Use encantado if the speaker is male and encantada if the speaker is female."
      },
      {
        "title": "Returning the question",
        "text": "After answering ¿cómo estás?, add ¿y tú? or ¿y usted? to keep the conversation going."
      }
    ],
    "examples": [
      {
        "spanish": "Hola, me llamo Tom. ¿Y usted?",
        "english": "Hello, my name is Tom. And you?"
      },
      {
        "spanish": "Mucho gusto, soy Ana.",
        "english": "Nice to meet you, I am Ana."
      }
    ],
    "practicePrompt": "Introduce yourself formally and informally."
  },
