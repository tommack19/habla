  "grammar": {
    "topic": "Necesitar, tener que, and classroom requests",
    "explanation": "Use necesito for I need and tengo que for I have to. Carlos guides you to ask simple classroom questions politely. Boleto? no. Use permiso, ayuda, or una pregunta in class.",
    "examples": [
      {
        "spanish": "Necesito un lapiz.",
        "english": "I need a pencil."
      },
      {
        "spanish": "Tengo que estudiar hoy.",
        "english": "I have to study today."
      },
      {
        "spanish": "Tengo una pregunta.",
        "english": "I have a question."
      }
    ],
    "practicePrompt": "Tell Carlos what class you have today, what supplies you need, and one thing you have to study."
  },
