  "grammar": {
    "topic": "Hace, esta, and hay for weather",
    "explanation": "Use hace with general weather or temperature, esta with current conditions, and hay to say there is or there are. Carlos reminds you that Spanish often says it makes heat instead of it is hot.",
    "examples": [
      {
        "spanish": "Hace frio hoy.",
        "english": "It is cold today."
      },
      {
        "spanish": "Esta nublado esta tarde.",
        "english": "It is cloudy this afternoon."
      },
      {
        "spanish": "Hay viento en la playa.",
        "english": "There is wind at the beach."
      }
    ],
    "practicePrompt": "Tell Carlos what the weather is like today and what you want to wear or do."
  },
