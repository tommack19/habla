  "culture": {
    "title": "Emotions in real life",
    "text": "Spanish conversations often include checking on people. Carlos teaches simple emotional honesty without over-sharing."
  },
  "nativeSpeech": {
    "title": "Carlos native speaker tips",
    "notes": [
      "Que tal? can ask how someone is feeling in a casual way.",
      "Estoy bien can mean I am okay, not only physically well.",
      "Un poco makes feelings softer and more natural."
    ]
  },
  "nativeExpressions": [
    "Que tal? can ask how someone is feeling in a casual way.",
    "Estoy bien can mean I am okay, not only physically well.",
    "Un poco makes feelings softer and more natural."
  ],
  "commonMistakes": [
    {
      "mistake": "Saying soy feliz for temporary mood.",
      "correction": "Say estoy feliz for how you feel now.",
      "explanation": "Emotions often use estar."
    },
    {
      "mistake": "Forgetting gender agreement.",
      "correction": "Say cansado/cansada, nervioso/nerviosa.",
      "explanation": "Many feeling words change by gender."
    },
    {
      "mistake": "Using por que instead of porque in answers.",
      "correction": "Use porque for because.",
      "explanation": "Porque gives a reason."
    }
  ],
