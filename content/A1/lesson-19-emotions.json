  "grammar": {
    "topic": "Estar with emotions and porque",
    "explanation": "Use estar for feelings that can change. Add porque to give a simple reason. Carlos helps you sound warm and human, not robotic.",
    "examples": [
      {
        "spanish": "Estoy feliz porque veo a mi familia.",
        "english": "I am happy because I see my family."
      },
      {
        "spanish": "Estoy nervioso hoy.",
        "english": "I am nervous today."
      },
      {
        "spanish": "Estas bien?",
        "english": "Are you okay?"
      }
    ],
    "practicePrompt": "Tell Carlos how you feel today and give one reason with porque."
  },
