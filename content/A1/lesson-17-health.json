  "culture": {
    "title": "Health in real life",
    "text": "In many Spanish-speaking places, pharmacies can help with minor issues. Carlos reminds learners to use clear, simple phrases and seek professional help for serious symptoms."
  },
  "nativeSpeech": {
    "title": "Carlos native speaker tips",
    "notes": [
      "Me encuentro mal is common in Spain for I feel unwell.",
      "Tengo gripa may be heard in parts of Latin America; gripe is widely understood.",
      "Use urgente only when something is truly urgent."
    ]
  },
